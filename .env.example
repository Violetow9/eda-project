# PostgreSQL
POSTGRES_HOST=postgresql
POSTGRES_PORT=5432
POSTGRES_DB=taskflow
POSTGRES_USER=taskflow
POSTGRES_PASSWORD=taskflow
POSTGRES_SYNCHRONIZE=true
POSTGRES_LOGGING=false

# JWT
JWT_ACCESS_SECRET=change-me-in-production
JWT_ACCESS_TTL=30d

# Api (NestJS)
PORT=3000

# Web (Next.js)
WEB_PORT=3001

# SMTP (use mailpit locally — UI on http://localhost:8025)
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_STARTTLS=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@taskflow.local